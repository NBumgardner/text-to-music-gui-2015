; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Text To Music GUI"
run/main_scene="res://scenes/text_to_music_gui/TextToMusicGui.tscn"
config/features=PackedStringArray("4.4", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

SoundManager="*res://addons/sound_manager/sound_manager.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/sound_manager/plugin.cfg")

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
