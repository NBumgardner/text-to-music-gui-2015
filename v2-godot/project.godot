; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Text To Music GUI"
config/description="Want to hear your name as a song? This GUI turns text into melodies."
config/tags=PackedStringArray("2d", "audio", "gui")
run/main_scene="res://scenes/main/main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="uid://b2lyv5r18s42n"

[display]

window/size/viewport_width=720
window/size/viewport_height=500
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_height"
window/handheld/orientation=1

[editor_plugins]

enabled=PackedStringArray("res://addons/onscreenkeyboard/addons/onscreenkeyboard/plugin.cfg")

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
